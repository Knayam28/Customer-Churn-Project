      <table>
        <view>
          <datasources>
            <datasource caption='Clean DataForTableau' name='federated.1yrjyf11ty8rle18znodf0f3nx4o' />
          </datasources>
          <datasource-dependencies datasource='federated.1yrjyf11ty8rle18znodf0f3nx4o'>
            <column caption='Highlight Tenure' datatype='string' name='[Calculation_1028882269417472]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_1446420739387394] = &apos;0-3 M&apos;&#13;&#10;THEN &apos;Highest Churn&apos;&#13;&#10;ELSE &apos;Other&apos;&#13;&#10;END' />
            </column>
            <column caption='Tenure Group' datatype='string' name='[Calculation_1446420739387394]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF ISNULL([Tenure]) THEN &quot;Unknown&quot;&#13;&#10;ELSEIF [Tenure] &gt;= 0 AND [Tenure] &lt;= 3 THEN &quot;0-3 M&quot;&#13;&#10;ELSEIF [Tenure] &gt;= 4 AND [Tenure] &lt;= 6 THEN &quot;4-6 M&quot;&#13;&#10;ELSEIF [Tenure] &gt;= 7 AND [Tenure] &lt;= 12 THEN &quot;7-12 M&quot;&#13;&#10;ELSEIF [Tenure] &gt;= 13 AND [Tenure] &lt;= 24 THEN &quot;13-24 M&quot;&#13;&#10;ELSE &quot;25+ M&quot;&#13;&#10;END' />
            </column>
            <column datatype='integer' name='[Churn]' role='measure' type='quantitative' />
            <column datatype='integer' name='[Tenure]' role='measure' type='quantitative' />
            <column-instance column='[Churn]' derivation='Avg' name='[avg:Churn:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1028882269417472]' derivation='None' name='[none:Calculation_1028882269417472:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1446420739387394]' derivation='None' name='[none:Calculation_1446420739387394:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1yrjyf11ty8rle18znodf0f3nx4o].[Exclusions (Highlight Tenure,Tenure Group)]'>
            <groupfilter function='except' user:ui-domain='database' user:ui-enumeration='exclusive' user:ui-marker='enumerate'>
              <groupfilter function='crossjoin'>
                <groupfilter function='level-members' level='[none:Calculation_1028882269417472:nk]' />
                <groupfilter function='level-members' level='[none:Calculation_1446420739387394:nk]' />
              </groupfilter>
              <groupfilter function='crossjoin'>
                <groupfilter function='member' level='[none:Calculation_1028882269417472:nk]' member='&quot;Other&quot;' />
                <groupfilter function='member' level='[none:Calculation_1446420739387394:nk]' member='&quot;Unknown&quot;' />
              </groupfilter>
            </groupfilter>
          </filter>
          <filter class='categorical' column='[federated.1yrjyf11ty8rle18znodf0f3nx4o].[none:Calculation_1446420739387394:nk]'>
            <groupfilter function='level-members' level='[none:Calculation_1446420739387394:nk]' user:ui-enumeration='all' user:ui-exclude='true' user:ui-marker='enumerate' />
